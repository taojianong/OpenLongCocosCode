{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "lib": [
            "ES2017",
            "DOM"
        ],
        "outDir": "./dist",
        "rootDir": "./",
        "declaration": false,
        "sourceMap": false,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"],
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "editor.d.ts",
        "main.ts",
        "panels/**/*.ts",
        "resource-copy-handler.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "scene-script.js"
    ]
}